<Window
    x:Class="Nagi.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Nagi">

    <Grid>
        <!-- Main Content -->
        <!-- This will be populated by code-behind/navigation -->

        <!-- Hidden container for generating taskbar icons -->
        <Grid Width="0" Height="0" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Visible">
            <Grid x:Name="TaskbarIconHost" Opacity="1" IsHitTestVisible="False" />
        </Grid>
    </Grid>

</Window>